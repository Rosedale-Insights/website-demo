{
	"mcpServers": {
		"github": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
			}
		},
		"neon": {
			"command": "npx",
			"args": ["-y", "mcp-remote", "https://mcp.neon.tech/sse"],
			"env": {
				"NEON_API_KEY": "${NEON_API_KEY}"
			}
		},
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"]
		}
	}
}
